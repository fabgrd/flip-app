    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^15.7.3",
    "react-intl": "^7.1.11",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.25.1",
